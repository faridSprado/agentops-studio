{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CampaignOutput",
  "type": "object",
  "required": ["title", "summary", "brief", "channels", "sections", "score", "revisions"],
  "properties": {
    "title": {"type": "string"},
    "summary": {"type": "string"},
    "brief": {"type": "string"},
    "channels": {"type": "array", "items": {"type": "string"}},
    "score": {"type": "integer"},
    "revisions": {"type": "integer"},
    "sections": {"type": "object"}
  }
}
